@model List<SaleItem>

<table class="table table-bordered" id="SaleItemsTable">
    <thead class="table-light">
        <tr>
            <th>Medicine Name</th>
            <th>Quantity</th>
            <th>Unit Price</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>
                    @* Change asp-for to explicit name and value *@
                    <input type="text" name="SaleItems[@i].MedicineName" value="@Model[i].MedicineName" class="form-control" required />
                </td>
                <td>
                    <input type="number" name="SaleItems[@i].Quantity" value="@Model[i].Quantity" class="form-control" required />
                </td>
                <td>
                    <input type="number" step="0.01" name="SaleItems[@i].UnitPrice" value="@Model[i].UnitPrice" class="form-control" required />
                </td>
                <td>
                    <button type="button" class="btn btn-danger" onclick="DeleteItem(this)">Remove</button>
                </td>
            </tr>
        }
    </tbody>
</table>